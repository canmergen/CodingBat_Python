SELECT
    q.DONEM_TIPI, q.DONEM_LABEL, q.BRACKET,
    q.INFLOW, q.OUTFLOW, q.TOTAL_HACIM,
    ABS(ROUND(SUM(q.INFLOW)  OVER (PARTITION BY q.DONEM_TIPI, q.DONEM_LABEL) /
              NULLIF(SUM(q.TOTAL_HACIM) OVER (PARTITION BY q.DONEM_TIPI, q.DONEM_LABEL), 0) * 100, 6)) AS TOTAL_INFLOW_RATE_PERC,
    ABS(ROUND(SUM(q.OUTFLOW) OVER (PARTITION BY q.DONEM_TIPI, q.DONEM_LABEL) /
              NULLIF(SUM(q.TOTAL_HACIM) OVER (PARTITION BY q.DONEM_TIPI, q.DONEM_LABEL), 0) * 100, 6)) AS TOTAL_OUTFLOW_RATE_PERC
FROM (
    SELECT
        COALESCE(A.DONEM_TIPI,  B.DONEM_TIPI,  C.DONEM_TIPI)  AS DONEM_TIPI,
        COALESCE(A.DONEM_LABEL, B.DONEM_LABEL, C.DONEM_LABEL) AS DONEM_LABEL,
        COALESCE(A.BRACKET, B.BRACKET, C.BRACKET)             AS BRACKET,
        NVL(A.INFLOW, 0) AS INFLOW, NVL(C.OUTFLOW, 0) AS OUTFLOW, NVL(B.TOTAL_HACIM, 0) AS TOTAL_HACIM
    FROM (
        SELECT DONEM_TIPI, DONEM_LABEL, FARK_BRACKET    AS BRACKET, SUM(FARK)            AS INFLOW
        FROM CTE_FLOW WHERE INFLOW_OUTFLOW = 'INFLOW' AND FARK_BRACKET <> '00:0K'
        GROUP BY DONEM_TIPI, DONEM_LABEL, FARK_BRACKET
    ) A
    FULL OUTER JOIN (
        SELECT DONEM_TIPI, DONEM_LABEL, T_EKSI1_BRACKET AS BRACKET, SUM(T_EKSI1_BAKIYE) AS TOTAL_HACIM
        FROM CTE_FLOW WHERE T_EKSI1_BRACKET <> '00:0K'
        GROUP BY DONEM_TIPI, DONEM_LABEL, T_EKSI1_BRACKET
    ) B ON A.DONEM_TIPI = B.DONEM_TIPI AND A.DONEM_LABEL = B.DONEM_LABEL AND A.BRACKET = B.BRACKET
    FULL OUTER JOIN (
        SELECT DONEM_TIPI, DONEM_LABEL, T_EKSI2_BRACKET AS BRACKET, SUM(FARK)            AS OUTFLOW
        FROM CTE_FLOW WHERE INFLOW_OUTFLOW = 'OUTFLOW' AND T_EKSI2_BRACKET <> '00:0K'
        GROUP BY DONEM_TIPI, DONEM_LABEL, T_EKSI2_BRACKET
    ) C ON COALESCE(A.DONEM_TIPI, B.DONEM_TIPI) = C.DONEM_TIPI
       AND COALESCE(A.DONEM_LABEL, B.DONEM_LABEL) = C.DONEM_LABEL
       AND COALESCE(A.BRACKET, B.BRACKET) = C.BRACKET
    WHERE COALESCE(A.BRACKET, B.BRACKET, C.BRACKET) <> '00:0K'
) q
ORDER BY q.DONEM_TIPI DESC, q.DONEM_LABEL, q.BRACKET;
