        t.RAPOR_TARIHI,
        t.MUSTERI_NO,
        t.PARA_KODU,
        t.VADELI_BAKIYE,
        t.VADESIZ_BAKIYE
    FROM PRSN.TURUNCU_YENI t
    CROSS JOIN PARAMS p
    WHERE t.RAPOR_TARIHI BETWEEN p.T_MIN AND p.T_MAX
      AND t.CALISMA_SEKLI = 1
),

/* Adım 1: TL (PARA_KODU=0) bakiyeleri — doğrudan CTE_BASE'den, tek adımda */
CTE_TL_BAKIYE AS (
    SELECT /*+ MATERIALIZE */
        RAPOR_TARIHI,
        MUSTERI_NO,
        SUM(VADELI_BAKIYE + VADESIZ_BAKIYE) AS TL_BAKIYE
    FROM CTE_BASE
    WHERE PARA_KODU = 0
    GROUP BY RAPOR_TARIHI, MUSTERI_NO
    HAVING SUM(VADELI_BAKIYE) > 0    -- sadece vadeli bakiyesi olanlar
),

/* Adım 2: Tarih çiftleri */
CTE_DATE_PAIRS AS (
    SELECT
        (SELECT T_MIN FROM PARAMS) + NUMTODSINTERVAL(LEVEL, 'DAY')     AS D_EKSI1,
        (SELECT T_MIN FROM PARAMS) + NUMTODSINTERVAL(LEVEL - 1, 'DAY') AS D_EKSI2,
        'GUNLUK' AS DONEM_TIPI,
        TO_CHAR(CAST((SELECT T_MIN FROM PARAMS) + NUMTODSINTERVAL(LEVEL, 'DAY') AS DATE), 'DD.MM.YYYY') AS DONEM_LABEL
    FROM DUAL
